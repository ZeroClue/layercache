{
  "$defs": {
    "AnthropicProviderConfig": {
      "description": "Anthropic-specific provider configuration.",
      "properties": {
        "api_key_env": {
          "description": "Environment variable name that holds the API key",
          "title": "Api Key Env",
          "type": "string"
        },
        "base_url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Override the default API base URL for this provider",
          "title": "Base Url"
        },
        "default_model": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Default model to use when the request omits the model field",
          "title": "Default Model"
        },
        "max_retries": {
          "default": 3,
          "description": "Maximum number of retries on transient failures",
          "maximum": 10,
          "minimum": 0,
          "title": "Max Retries",
          "type": "integer"
        },
        "timeout": {
          "default": 120,
          "description": "Request timeout in seconds",
          "minimum": 1,
          "title": "Timeout",
          "type": "integer"
        },
        "use_auto_cache_control": {
          "default": false,
          "description": "[P1 deferred] Automatically inject cache_control markers on system and historical messages",
          "title": "Use Auto Cache Control",
          "type": "boolean"
        }
      },
      "required": [
        "api_key_env"
      ],
      "title": "AnthropicProviderConfig",
      "type": "object"
    },
    "CachingConfig": {
      "description": "Caching configuration.",
      "properties": {
        "semantic": {
          "$ref": "#/$defs/SemanticCacheConfig",
          "description": "Semantic cache settings"
        },
        "metrics": {
          "$ref": "#/$defs/MetricsConfig",
          "description": "Metrics snapshot storage settings"
        },
        "max_session_tokens": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional: truncate L2 to fit within this token budget (null = no truncation)",
          "title": "Max Session Tokens"
        }
      },
      "title": "CachingConfig",
      "type": "object"
    },
    "EnhancementConfig": {
      "description": "Single enhancement plugin configuration.",
      "properties": {
        "name": {
          "description": "Unique name used to reference this enhancement in requests (lc_enhancements)",
          "title": "Name",
          "type": "string"
        },
        "class_path": {
          "description": "Python dotted path to the enhancement class, e.g. layercache.enhancements.chain_of_thought.ChainOfThoughtEnhancement",
          "title": "Class Path",
          "type": "string"
        },
        "config": {
          "additionalProperties": true,
          "description": "Arbitrary keyword arguments passed to the enhancement constructor",
          "title": "Config",
          "type": "object"
        }
      },
      "required": [
        "name",
        "class_path"
      ],
      "title": "EnhancementConfig",
      "type": "object"
    },
    "EnhancementsConfig": {
      "description": "Enhancements configuration.",
      "properties": {
        "registered": {
          "description": "List of registered enhancement plugins",
          "items": {
            "$ref": "#/$defs/EnhancementConfig"
          },
          "title": "Registered",
          "type": "array"
        }
      },
      "title": "EnhancementsConfig",
      "type": "object"
    },
    "MetricsConfig": {
      "description": "Metrics snapshot storage configuration.",
      "properties": {
        "db_path": {
          "default": "/data/metrics.db",
          "description": "Path to the metrics SQLite database",
          "title": "Db Path",
          "type": "string"
        },
        "snapshot_interval_seconds": {
          "default": 60,
          "description": "Seconds between background metric snapshots",
          "exclusiveMinimum": 0,
          "title": "Snapshot Interval Seconds",
          "type": "integer"
        },
        "snapshot_retention_days": {
          "default": 7,
          "description": "Days to retain metric snapshots before pruning",
          "exclusiveMinimum": 0,
          "title": "Snapshot Retention Days",
          "type": "integer"
        }
      },
      "title": "MetricsConfig",
      "type": "object"
    },
    "ProviderConfig": {
      "description": "Single LLM provider configuration.",
      "properties": {
        "api_key_env": {
          "description": "Environment variable name that holds the API key",
          "title": "Api Key Env",
          "type": "string"
        },
        "base_url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Override the default API base URL for this provider",
          "title": "Base Url"
        },
        "default_model": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Default model to use when the request omits the model field",
          "title": "Default Model"
        },
        "max_retries": {
          "default": 3,
          "description": "Maximum number of retries on transient failures",
          "maximum": 10,
          "minimum": 0,
          "title": "Max Retries",
          "type": "integer"
        },
        "timeout": {
          "default": 120,
          "description": "Request timeout in seconds",
          "minimum": 1,
          "title": "Timeout",
          "type": "integer"
        }
      },
      "required": [
        "api_key_env"
      ],
      "title": "ProviderConfig",
      "type": "object"
    },
    "ProvidersConfig": {
      "description": "All provider configurations.",
      "properties": {
        "anthropic": {
          "anyOf": [
            {
              "$ref": "#/$defs/AnthropicProviderConfig"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Anthropic provider settings"
        },
        "openai": {
          "anyOf": [
            {
              "$ref": "#/$defs/ProviderConfig"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "OpenAI provider settings"
        },
        "gemini": {
          "anyOf": [
            {
              "$ref": "#/$defs/ProviderConfig"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Google Gemini provider settings"
        }
      },
      "title": "ProvidersConfig",
      "type": "object"
    },
    "ProxyConfig": {
      "description": "Proxy server configuration.",
      "properties": {
        "host": {
          "default": "0.0.0.0",
          "description": "Bind address for the HTTP server",
          "title": "Host",
          "type": "string"
        },
        "port": {
          "default": 8000,
          "description": "Port for the HTTP server",
          "maximum": 65535,
          "minimum": 1,
          "title": "Port",
          "type": "integer"
        },
        "proxy_api_key": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional bearer token to authenticate proxy clients",
          "title": "Proxy Api Key"
        },
        "log_level": {
          "default": "info",
          "description": "Log level (debug, info, warning, error)",
          "title": "Log Level",
          "type": "string"
        }
      },
      "title": "ProxyConfig",
      "type": "object"
    },
    "SemanticCacheConfig": {
      "description": "Semantic cache configuration.",
      "properties": {
        "enabled": {
          "default": true,
          "description": "Enable the semantic cache (embedding-based query matching)",
          "title": "Enabled",
          "type": "boolean"
        },
        "backend": {
          "default": "sqlite",
          "description": "Cache backend (currently only sqlite)",
          "title": "Backend",
          "type": "string"
        },
        "db_path": {
          "default": "/data/semantic_cache.db",
          "description": "Path to the SQLite database file",
          "title": "Db Path",
          "type": "string"
        },
        "default_ttl": {
          "default": 300,
          "description": "Default TTL in seconds for cache entries (0 = no expiry)",
          "minimum": 0,
          "title": "Default Ttl",
          "type": "integer"
        },
        "similarity_threshold": {
          "default": 0.95,
          "description": "Minimum cosine similarity score for a semantic cache hit",
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Similarity Threshold",
          "type": "number"
        },
        "embedder": {
          "default": "BAAI/bge-small-en-v1.5",
          "description": "FastEmbed model name for generating query embeddings",
          "title": "Embedder",
          "type": "string"
        }
      },
      "title": "SemanticCacheConfig",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Configuration schema for layercache.yaml",
  "properties": {
    "proxy": {
      "$ref": "#/$defs/ProxyConfig",
      "description": "Proxy server settings"
    },
    "providers": {
      "$ref": "#/$defs/ProvidersConfig",
      "description": "LLM provider settings"
    },
    "caching": {
      "$ref": "#/$defs/CachingConfig",
      "description": "Caching behaviour"
    },
    "enhancements": {
      "$ref": "#/$defs/EnhancementsConfig",
      "description": "Prompt enhancement plugins"
    }
  },
  "title": "LayerCache Configuration",
  "type": "object",
  "$id": "https://layercache.ai/schemas/layercache.schema.json",
  "$schema": "https://json-schema.org/draft-07/schema#"
}
