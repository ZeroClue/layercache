{
  "$defs": {
    "CachingConfig": {
      "description": "Caching configuration.",
      "properties": {
        "semantic": {
          "$ref": "#/$defs/SemanticCacheConfig",
          "description": "Semantic cache settings"
        },
        "metrics": {
          "$ref": "#/$defs/MetricsConfig",
          "description": "Metrics snapshot storage settings"
        },
        "max_session_tokens": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Max L2 tokens before truncation (null = no limit)",
          "title": "Max Session Tokens"
        },
        "prefix_hash_max_tokens": {
          "default": 250,
          "description": "Max L0 tokens included in prefix hash. Truncating to the first N tokens excludes per-project context (CLAUDE.md, AGENTS.md) that's appended after the stable boilerplate, enabling cross-project cache hits.",
          "maximum": 4096,
          "minimum": 50,
          "title": "Prefix Hash Max Tokens",
          "type": "integer"
        },
        "truncation_strategy": {
          "default": "recent",
          "description": "Truncation strategy for session management (semantic deferred to v1.6)",
          "pattern": "^(recent|important|trim|semantic)$",
          "title": "Truncation Strategy",
          "type": "string"
        },
        "token_counter": {
          "default": "tiktoken",
          "description": "Token counting method (tiktoken = accurate, char_estimate = fast approx)",
          "pattern": "^(tiktoken|char_estimate)$",
          "title": "Token Counter",
          "type": "string"
        },
        "litellm_model": {
          "default": "gpt-4o",
          "description": "Model for LiteLLM trim_messages (trim strategy)",
          "title": "Litellm Model",
          "type": "string"
        }
      },
      "title": "CachingConfig",
      "type": "object"
    },
    "EnhancementConfig": {
      "description": "Single enhancement plugin configuration.",
      "properties": {
        "name": {
          "description": "Reference name used in lc_enhancements requests",
          "title": "Name",
          "type": "string"
        },
        "class_path": {
          "description": "Python dotted path to the enhancement class",
          "title": "Class Path",
          "type": "string"
        },
        "config": {
          "additionalProperties": true,
          "description": "Keyword arguments passed to the constructor",
          "title": "Config",
          "type": "object"
        }
      },
      "required": [
        "name",
        "class_path"
      ],
      "title": "EnhancementConfig",
      "type": "object"
    },
    "EnhancementsConfig": {
      "description": "Enhancements configuration.",
      "properties": {
        "registered": {
          "description": "Registered enhancement plugins",
          "items": {
            "$ref": "#/$defs/EnhancementConfig"
          },
          "title": "Registered",
          "type": "array"
        }
      },
      "title": "EnhancementsConfig",
      "type": "object"
    },
    "MetricsConfig": {
      "description": "Metrics snapshot storage configuration.",
      "properties": {
        "db_path": {
          "default": "/data/metrics.db",
          "description": "Path to the metrics SQLite database",
          "title": "Db Path",
          "type": "string"
        },
        "snapshot_interval_seconds": {
          "default": 60,
          "description": "Seconds between metric snapshots",
          "exclusiveMinimum": 0,
          "title": "Snapshot Interval Seconds",
          "type": "integer"
        },
        "snapshot_retention_days": {
          "default": 7,
          "description": "Days to retain metric snapshots",
          "exclusiveMinimum": 0,
          "title": "Snapshot Retention Days",
          "type": "integer"
        }
      },
      "title": "MetricsConfig",
      "type": "object"
    },
    "MultiTierConfig": {
      "description": "Multi-tier caching configuration.",
      "properties": {
        "enabled": {
          "default": true,
          "description": "Enable multi-tier cache hierarchy (semantic \u2192 prefix \u2192 inference)",
          "title": "Enabled",
          "type": "boolean"
        },
        "validation_latency_budget_ms": {
          "default": 50,
          "description": "Maximum validation latency budget in milliseconds (p95)",
          "minimum": 1,
          "title": "Validation Latency Budget Ms",
          "type": "integer"
        },
        "probation_threshold": {
          "default": 10,
          "description": "Number of successful validations before promotion from probation",
          "minimum": 1,
          "title": "Probation Threshold",
          "type": "integer"
        },
        "probation_auto_promotion_seconds": {
          "default": 3600,
          "description": "Seconds before auto-promotion from probation regardless of count",
          "minimum": 60,
          "title": "Probation Auto Promotion Seconds",
          "type": "integer"
        },
        "max_probation_entries": {
          "default": 1000,
          "description": "Maximum entries to keep in probation (LRU eviction)",
          "minimum": 100,
          "title": "Max Probation Entries",
          "type": "integer"
        }
      },
      "title": "MultiTierConfig",
      "type": "object"
    },
    "ProviderConfig": {
      "description": "Single LLM provider configuration.",
      "properties": {
        "api_key_env": {
          "description": "Env var name holding the provider API key",
          "title": "Api Key Env",
          "type": "string"
        },
        "base_url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Override the default API base URL",
          "title": "Base Url"
        },
        "default_model": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Default model if the request omits the model field",
          "title": "Default Model"
        },
        "max_retries": {
          "default": 3,
          "description": "Maximum retries on transient failures",
          "maximum": 10,
          "minimum": 0,
          "title": "Max Retries",
          "type": "integer"
        },
        "timeout": {
          "default": 120,
          "description": "Request timeout in seconds",
          "minimum": 1,
          "title": "Timeout",
          "type": "integer"
        },
        "adapter": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Cache adapter (anthropic, gemini, openai); auto-detected from model name if unset",
          "title": "Adapter"
        },
        "model_aliases": {
          "additionalProperties": {
            "type": "string"
          },
          "description": "Model name aliases: maps alias -> upstream model name. Applied when the request model matches an alias key.",
          "title": "Model Aliases",
          "type": "object"
        }
      },
      "required": [
        "api_key_env"
      ],
      "title": "ProviderConfig",
      "type": "object"
    },
    "ProvidersConfig": {
      "additionalProperties": {
        "$ref": "#/$defs/ProviderConfig"
      },
      "default": {},
      "description": "All provider configurations \u2014 a dict of provider name -> config.\n\nKeys are arbitrary labels (e.g. \"anthropic\", \"openai\", \"deepseek\").\nEach value configures how the proxy connects to that provider.",
      "title": "ProvidersConfig",
      "type": "object"
    },
    "ProxyConfig": {
      "description": "Proxy server configuration.",
      "properties": {
        "host": {
          "default": "0.0.0.0",
          "description": "Bind address for the HTTP server",
          "title": "Host",
          "type": "string"
        },
        "port": {
          "default": 8000,
          "description": "Port for the HTTP server",
          "maximum": 65535,
          "minimum": 1,
          "title": "Port",
          "type": "integer"
        },
        "proxy_api_key": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Bearer token for client authentication",
          "title": "Proxy Api Key"
        },
        "log_level": {
          "default": "info",
          "description": "Log level (debug, info, warning, error)",
          "title": "Log Level",
          "type": "string"
        }
      },
      "title": "ProxyConfig",
      "type": "object"
    },
    "SemanticCacheConfig": {
      "description": "Semantic cache configuration.",
      "properties": {
        "enabled": {
          "default": true,
          "description": "Enable embedding-based semantic cache",
          "title": "Enabled",
          "type": "boolean"
        },
        "backend": {
          "default": "sqlite",
          "description": "Cache backend (sqlite or redis)",
          "pattern": "^(sqlite|redis)$",
          "title": "Backend",
          "type": "string"
        },
        "db_path": {
          "default": "/data/semantic_cache.db",
          "description": "Path to the SQLite database file",
          "title": "Db Path",
          "type": "string"
        },
        "redis_url": {
          "default": "redis://localhost:6379/0",
          "description": "Redis connection URL (used when backend=redis)",
          "title": "Redis Url",
          "type": "string"
        },
        "redis_pool_size": {
          "default": 10,
          "description": "Redis connection pool size",
          "maximum": 100,
          "minimum": 1,
          "title": "Redis Pool Size",
          "type": "integer"
        },
        "redis_timeout": {
          "default": 5.0,
          "description": "Redis socket timeout in seconds",
          "exclusiveMinimum": 0,
          "title": "Redis Timeout",
          "type": "number"
        },
        "default_ttl": {
          "default": 3600,
          "description": "Default TTL in seconds (0 = no expiry)",
          "minimum": 0,
          "title": "Default Ttl",
          "type": "integer"
        },
        "similarity_threshold": {
          "default": 0.95,
          "description": "Minimum cosine similarity for a cache hit",
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Similarity Threshold",
          "type": "number"
        },
        "embedder": {
          "default": "BAAI/bge-small-en-v1.5",
          "description": "FastEmbed model for query embeddings",
          "title": "Embedder",
          "type": "string"
        },
        "session_id_header": {
          "default": "X-Session-ID",
          "description": "HTTP header name for session ID (opt-in isolation)",
          "title": "Session Id Header",
          "type": "string"
        },
        "session_id_auto_generate": {
          "default": false,
          "description": "Auto-generate session ID if not provided (breaks cross-request cache hits)",
          "title": "Session Id Auto Generate",
          "type": "boolean"
        },
        "multi_tier": {
          "$ref": "#/$defs/MultiTierConfig",
          "description": "Multi-tier caching hierarchy settings"
        }
      },
      "title": "SemanticCacheConfig",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Configuration schema for layercache.yaml",
  "properties": {
    "proxy": {
      "$ref": "#/$defs/ProxyConfig",
      "description": "Proxy server settings"
    },
    "providers": {
      "$ref": "#/$defs/ProvidersConfig",
      "description": "LLM provider settings (dict of name -> config)"
    },
    "caching": {
      "$ref": "#/$defs/CachingConfig",
      "description": "Caching behaviour"
    },
    "enhancements": {
      "$ref": "#/$defs/EnhancementsConfig",
      "description": "Prompt enhancement plugins"
    }
  },
  "title": "LayerCache Configuration",
  "type": "object",
  "$id": "https://layercache.ai/schemas/layercache.schema.json",
  "$schema": "https://json-schema.org/draft-07/schema#"
}
